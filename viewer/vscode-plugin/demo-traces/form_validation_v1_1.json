        "src_code": "function validateSignup(email: string, password: string): ValidationResult {\n  const errors: string[] = [];\n  if (!email.includes('@')) errors.push('Invalid email');\n  if (password.length < 8) errors.push('Password too short');\n  if (password === email) errors.push('Password cannot be email');\n  return { valid: errors.length === 0, errors };\n}",
        "iml_code": "type validation_result = { valid : bool; errors : string list }\n\nlet validate_email (email : string) : string option =\n  if not (String.contains email '@') then Some \"Invalid email\"\n  else if String.length email < 3 then Some \"Email too short\"\n  else if not (String.contains (String.after email '@') '.') then Some \"Missing domain\"\n  else None\n\nlet validate_password (password : string) (email : string) : string option =\n  if String.length password < 8 then Some \"Password too short\"\n  else if String.equal password email then Some \"Password cannot be email\"\n  else None\n\nlet validate_signup (email : string) (password : string) : validation_result =\n  let errs = List.filter_map Fun.id\n    [validate_email email; validate_password password email] in\n  { valid = List.length errs = 0; errors = errs }",
