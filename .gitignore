# Python
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
build/
dist/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node / website
node_modules/
website/dist/
website/.astro/
.cache/

# Generated site inputs (built by website/scripts/prepare.mjs)
website/public/gallery/
website/public/viewer/
website/src/pages/spec/*.md
# Viewer demo traces are synced from examples/ at build time (source: examples/)
viewer/vscode-plugin/media/demo-traces/

# Local registry cache
.ponens/

# Visualizer asset copied into the CLI package at build time (source: viewer/vscode-plugin/media/)
cli/ponens/visualizer.html

# Demo traces copied into the CLI package at build time (source: examples/, via cli/Makefile)
cli/ponens/demos/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Generated visualizer pages (regenerate: python3 examples/fix_ai_wg/view.py)
examples/fix_ai_wg/viewer/

# Generated from the OTLP sample (regenerate: ponens otel import examples/otel/sample-otlp.json)
examples/otel/*-trace.json

# Generated from the Langfuse sample (regenerate: ponens langfuse import examples/langfuse/sample-langfuse.json)
examples/langfuse/*-trace.json
