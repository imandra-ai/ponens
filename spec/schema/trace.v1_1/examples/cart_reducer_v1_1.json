      "summary": "IML formalization of cart reducer with discount support",
      "payload": {
        "status": "transparent",
        "src_lang": "typescript",
        "src_code": "type CartAction =\n  | { type: 'ADD_ITEM'; item: Item }\n  | { type: 'REMOVE_ITEM'; id: string }\n  | { type: 'UPDATE_QUANTITY'; id: string; qty: number }\n  | { type: 'CLEAR' }\n  | { type: 'APPLY_DISCOUNT'; code: string; percent: number }\n  | { type: 'REMOVE_DISCOUNT' };\n\nfunction cartReducer(state: CartState, action: CartAction): CartState { ... }",
        "iml_code": "type cart_action =\n  | AddItem of item\n  | RemoveItem of string\n  | UpdateQuantity of string * int\n  | Clear\n  | ApplyDiscount of string * int  (* code, percent 0-100 *)\n  | RemoveDiscount\n\ntype cart_state = {\n  items : (string * item * int) list;  (* id, item, qty *)\n  discount : (string * int) option;    (* code, percent *)\n  total : int;\n}\n\nlet cart_reducer (state : cart_state) (action : cart_action) : cart_state =\n  match action with\n  | AddItem item -> { state with items = (item.id, item, 1) :: state.items; total = recalc state }\n  | RemoveItem id -> { state with items = List.filter (fun (i,_,_) -> i <> id) state.items; total = recalc state }\n  | UpdateQuantity (id, qty) ->\n    if qty <= 0 then cart_reducer state (RemoveItem id)\n    else { state with items = List.map (fun (i,it,q) -> if i = id then (i,it,qty) else (i,it,q)) state.items; total = recalc state }\n  | Clear -> { items = []; discount = None; total = 0 }\n  | ApplyDiscount (code, pct) ->\n    if 0 < pct && pct <= 100 then { state with discount = Some (code, pct); total = recalc state }\n    else state\n  | RemoveDiscount -> { state with discount = None; total = recalc state }",
        "symbols": [
          "cart_action",
          "cart_state",
          "cart_reducer",
          "recalc"
        ]
      }
    },
