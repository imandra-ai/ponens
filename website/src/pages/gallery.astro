---
import Layout from "../layouts/Layout.astro";
// The catalog is synced into public/gallery at build time; fetched at runtime
// so the page is a thin browser over the same _catalog.json the CLI consumes.
---

<Layout title="Policy Gallery — ponens">
  <section class="gallery-head">
    <h1>Policy Gallery</h1>
    <p><strong>Computable Governance</strong> — best coding and reasoning practices encoded as
      machine-checkable rules over a trace. The same
      <a href="/gallery/policies/_catalog.json"><code>_catalog.json</code></a>
      is what <code>ponens registry update</code> pulls. Want your own?
      <a href="/docs/writing-policies">Write a policy →</a></p>
    <p class="formula-hint">Hover any <span class="demo">operator or symbol</span> in a formula for what it means.</p>
    <input id="q" type="search" placeholder="Search policies, formulas, tags…" autocomplete="off" />
    <div id="packRow" class="filter-row" hidden><span class="filter-label">Pack</span><div id="packFilters" class="filters"></div></div>
    <div class="filter-row"><span class="filter-label">Domain</span><div id="domFilters" class="filters"></div></div>
    <div class="filter-row"><span class="filter-label">Category</span><div id="catFilters" class="filters"></div></div>
    <p class="gallery-orglink">Curated by an organization?
      <a href="/organizations">Browse policy packs by publisher →</a></p>
  </section>

  <div id="count" class="count"></div>
  <div id="grid" class="policy-grid"></div>

  <script>
    import { highlightFormula } from "../lib/formula-fmt.mjs";

    const grid = document.getElementById("grid");
    const countEl = document.getElementById("count");
    const q = document.getElementById("q");
    let all = [];
    let activeDomain = null;
    let activeCategory = null;
    let activePack = null;
    let packNames = {};

    const LL_LABEL = {
      pure_temporal: "Pure temporal",
      scoped_temporal: "Scoped temporal",
      structural: "Structural",
    };

    function render() {
      const query = q.value.trim().toLowerCase();
      const items = all.filter((p) => {
        if (activePack && p.pack !== activePack) return false;
        if (activeDomain && p.domain !== activeDomain) return false;
        if (activeCategory && p.category !== activeCategory) return false;
        if (!query) return true;
        const hay = `${p.id} ${p.name} ${p.description} ${p.domain} ${p.category} ${(p.tags || []).join(" ")} ${p.formula || ""}`.toLowerCase();
        return hay.includes(query);
      });
      countEl.textContent = `${items.length} of ${all.length} policies`;
      grid.innerHTML = items
        .map(
          (p) => `
        <a class="policy-card" href="/policies/${p.id}">
          <div class="policy-top">
            <code class="pid">${p.id}</code>
            <span class="sev sev-${p.severity}">${p.severity}</span>
          </div>
          <h3>${p.name}</h3>
          <p>${p.description ?? ""}</p>
          ${p.formula ? `<pre class="pf"><code>${highlightFormula(p.formula)}</code></pre>` : ""}
          <div class="policy-meta">
            ${p.pack ? `<span class="pack-badge">${packNames[p.pack] ?? p.pack}</span>` : ""}
            <span class="dom">${p.domain ?? ""}</span>
            ${(p.tags || []).map((t) => `<span class="tag">${t}</span>`).join("")}
            ${p.language_level ? `<span class="ll ll-${p.language_level}">${LL_LABEL[p.language_level] ?? p.language_level}</span>` : ""}
          </div>
        </a>`
        )
        .join("");
    }

    function buildFilters(container, key, setActive, labelOf) {
      const counts = {};
      all.forEach((p) => {
        const v = p[key];
        if (v) counts[v] = (counts[v] || 0) + 1;
      });
      const total = Object.values(counts).reduce((a, b) => a + b, 0);
      const vals = Object.keys(counts).sort();
      const label = labelOf || ((v) => v);
      container.innerHTML =
        `<button class="chip active" data-v="">All <em>${total}</em></button>` +
        vals.map((v) => `<button class="chip" data-v="${v}">${label(v)} <em>${counts[v]}</em></button>`).join("");
      container.querySelectorAll("button").forEach((b) =>
        b.addEventListener("click", () => {
          setActive(b.dataset.v || null);
          container.querySelectorAll("button").forEach((x) => x.classList.remove("active"));
          b.classList.add("active");
          render();
        })
      );
    }

    fetch("/gallery/policies/_catalog.json")
      .then((r) => r.json())
      .then((cat) => {
        all = cat.policies || [];
        packNames = Object.fromEntries((cat.packs || []).map((p) => [p.id, p.name]));
        if ((cat.packs || []).length && all.some((p) => p.pack)) {
          document.getElementById("packRow").hidden = false;
          buildFilters(document.getElementById("packFilters"), "pack",
            (v) => (activePack = v), (v) => packNames[v] ?? v);
        }
        buildFilters(document.getElementById("domFilters"), "domain", (v) => (activeDomain = v));
        buildFilters(document.getElementById("catFilters"), "category", (v) => (activeCategory = v));
        render();
        // Deep link from an organization page: /gallery?pack=<id>
        const wantPack = new URLSearchParams(location.search).get("pack");
        if (wantPack && packNames[wantPack]) {
          activePack = wantPack;
          const btn = document.querySelector(`#packFilters button[data-v="${wantPack}"]`);
          if (btn) {
            document.querySelectorAll("#packFilters button").forEach((x) => x.classList.remove("active"));
            btn.classList.add("active");
          }
          render();
        }
      })
      .catch(() => {
        grid.innerHTML = `<p class="empty">Could not load the catalog. Run <code>npm run sync-gallery</code> in <code>website/</code>.</p>`;
      });

    q.addEventListener("input", render);
  </script>

  <style>
    .gallery-orglink { margin: 0.75rem 0 0; font-size: 0.9rem; color: var(--muted); }
    .pack-badge {
      font-size: 0.7rem; font-weight: 600; padding: 0.1rem 0.45rem; border-radius: 999px;
      background: color-mix(in srgb, #b3541e 16%, transparent); color: #b3541e;
      border: 1px solid color-mix(in srgb, #b3541e 35%, transparent); white-space: nowrap;
    }
  </style>
</Layout>
