type runtime_value =
  | RVString of string
  | RVInt of int
  | RVBool of bool
  | RVFloat of float
  | RVActionId of int
  | RVArtifactId of string
  | RVActionIds of int list
  | RVArtifactIds of string list
  | RVValues of runtime_value list
  | RVUnknown

type binding = {
  name : string;
  value : runtime_value;
}

type env = {
  current_pos : int;
  bindings : binding list;
}
