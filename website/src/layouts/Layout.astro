---
const { title = "ponens", description = "Author, govern, and validate the reasoning of AI coding agents." } = Astro.props;
const path = Astro.url.pathname;
const active = (p) => (path === p || (p !== "/" && path.startsWith(p)) ? "active" : "");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="stylesheet" href="/styles/global.css" />
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">∴ ponens</a>
      <nav>
        <a href="/gallery" class={active("/gallery")}>Gallery</a>
        <a href="/docs" class={active("/docs")}>Docs</a>
        <a href="/spec" class={active("/spec")}>Spec</a>
        <a href="/viewer" class={active("/viewer")}>Viewer</a>
        <a href="https://github.com/imandra-ai/ponens">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <span>∴ ponens — open governance for AI agent reasoning</span>
      <span>MIT · <a href="https://github.com/imandra-ai/ponens">imandra-ai/ponens</a></span>
    </footer>
  </body>
</html>
